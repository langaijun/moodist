---
import Layout from '@/layouts/layout.astro';

import Hero from '@/components/hero.astro';

import { App } from '@/components/app';
import CategoryIcons from '@/components/categories/category-icons/category-icons';
---

<Layout title="Moodist: Ambient Sounds for Focus and Calm">
  <div class="header">
    <h1 class="main-title">
      Ambient Sounds<span class="line">For Focus and Calm</span>
    </h1>
    <a
      aria-label="Support with a donation!"
      class="coffee-button"
      href="https://ko-fi.com/langaijun"
      rel="noreferrer"
      target="_blank"
    >
      <svg
        fill="currentColor"
        height="24"
        viewBox="0 0 24 24"
        width="24"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          d="M18.5 3H6c-1.1 0-2 .9-2 2v5.71c0 3.83 2.95 7.18 6.78 7.29 3.96.12 7.22-3.06 7.22-7v-1h.5c1.93 0 3.5-1.57 3.5-3.5S20.43 3 18.5 3zM16 5v3H8V5h8zm2.5 3H18V5h.5c.83 0 1.5.67 1.5 1.5S19.33 8 18.5 8zM4 19h16v2H4v-2z"
        ></path>
      </svg>
    </a>
  </div>
  <Hero />
  <CategoryIcons client:load />
  <App client:load />
</Layout>

<style>
  .header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1200px;
    padding: 20px 24px;
    margin: 0 auto;
  }

  .main-title {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--font-lg);
    font-weight: 600;
    line-height: 1.2;
    color: var(--color-foreground);

    & .line {
      display: block;
      margin-top: 2px;
      background: linear-gradient(
        var(--color-foreground-subtler),
        var(--color-foreground-subtle)
      );
      background-clip: text;
      -webkit-text-fill-color: transparent;
    }
  }

  .coffee-button {
    display: flex;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    color: #8b4513;
    text-decoration: none;
    cursor: pointer;
    background: linear-gradient(
      var(--color-neutral-100),
      var(--color-neutral-200)
    );
    border: 1px solid var(--color-neutral-300);
    border-radius: 50%;
    transition: 0.2s;
  }

  .coffee-button:hover {
    color: #6a3510;
    background: linear-gradient(
      var(--color-neutral-200),
      var(--color-neutral-300)
    );
    transform: scale(1.1);
  }

  .coffee-button:active {
    transform: scale(0.95);
  }

  @media (width <= 600px) {
    .header {
      padding: 16px 20px;
    }

    .main-title {
      font-size: var(--font-md);
    }

    .coffee-button {
      width: 40px;
      height: 40px;
    }
  }
</style>
